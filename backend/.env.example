MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=a_long_random_secret_string
PORT=5000
# production hides internal error details from API responses; leave unset
# (or "development") locally so you see real error messages while debugging.
NODE_ENV=production
# Comma-separated list of allowed frontend origins in production.
# Leave unset for local dev (allows all origins).
FRONTEND_URL=https://your-app.vercel.app

# Optional — enables the AI weak-area coach. Get a free key at
# https://aistudio.google.com/apikey. Leave unset to disable the feature
# (the app works fine without it, the coach card just won't be usable).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
