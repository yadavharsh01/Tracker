MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=a_long_random_secret_string
PORT=5000
# production hides internal error details from API responses; leave unset
# (or "development") locally so you see real error messages while debugging.
NODE_ENV=production
# Comma-separated list of allowed frontend origins in production.
# Leave unset for local dev (allows all origins).
FRONTEND_URL=https://your-app.vercel.app

# Optional — enables the AI weak-area coach. Get a free key at
# https://aistudio.google.com/apikey. Leave unset to disable the feature
# (the app works fine without it, the coach card just won't be usable).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# REQUIRED for password reset to work — forgot-password now returns a clear
# 503 error until these are set, rather than silently doing nothing (or, as it
# used to, showing the reset link directly in the UI — removed for security).
#
# Easiest free option: Gmail with an App Password (not your regular password):
#   1. Enable 2-Step Verification on the Google account: myaccount.google.com/security
#   2. Create an App Password: myaccount.google.com/apppasswords
#   3. SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com,
#      SMTP_PASS=<the 16-char app password>, EMAIL_FROM=you@gmail.com
# Alternative: any transactional email provider's SMTP relay (Brevo, Resend,
# SendGrid, Mailgun — all have free tiers).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Optional — auto-grants admin access to these emails on login (comma-separated).
# See the Admin section in README.md for what this unlocks.
ADMIN_EMAILS=

# Optional — enables OTP login by phone number (email OTP login reuses the
# SMTP settings above and needs no extra config). Get free trial credits at
# twilio.com/try-twilio; TWILIO_PHONE_NUMBER is the number Twilio gives you.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional — enables real browser push notifications (streak-risk reminders,
# test notifications from Settings). Generate a key pair locally with:
#   npx web-push generate-vapid-keys
# Without these, push notifications are simply unavailable — Settings shows
# a clear "not configured" message, nothing else in the app is affected.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
